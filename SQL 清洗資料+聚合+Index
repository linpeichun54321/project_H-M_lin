-- 建立客戶聚合表
SELECT 
    c.club_member_status,
    c.age,
    COUNT(t.customer_id) AS transaction_count,    -- 購買次數
    SUM(t.price) AS total_spent,                  -- 總消費金額
    MAX(t.t_dat) AS last_purchase_date            -- 最近一次購買日期 (Recency)
INTO [dbo].[agg_customer_behavior]
FROM [dbo].[clean_customers] c
JOIN [dbo].[clean_transactions] t ON c.customer_id = t.customer_id
GROUP BY 
    c.club_member_status, 
    c.age;


-- 建立產品聚合表
SELECT 
    a.product_group_name,
    a.perceived_colour_master_name,
    a.index_name,
    COUNT(t.article_id) AS total_units_sold,       -- 總銷量
    SUM(t.price) AS total_revenue,                -- 總營收
    AVG(t.price) AS avg_selling_price             -- 平均售價
INTO [dbo].[agg_article_performance]               -- 直接將結果存成新表
FROM [dbo].[clean_articles] a
JOIN [dbo].[clean_transactions] t ON a.article_id = t.article_id
GROUP BY 
    a.product_group_name, 
    a.perceived_colour_master_name, 
    a.index_name;

-- 幫交易表的客戶 ID 建索引
CREATE INDEX IX_Transactions_CustomerID ON [dbo].[clean_transactions] (customer_id);

-- 幫交易表的產品 ID 建索引
CREATE INDEX IX_Transactions_ArticleID ON [dbo].[clean_transactions] (article_id);

-- 幫交易日期建索引
CREATE INDEX IX_Transactions_Date ON [dbo].[clean_transactions] (t_dat);

SELECT 
    t_dat,
    DATENAME(weekday, t_dat) AS day_of_week,     -- 星期幾
    DATEPART(month, t_dat) AS sales_month,       -- 月份
    COUNT(customer_id) AS daily_transactions,    -- 每日單量
    SUM(price) AS daily_revenue,                 -- 每日營收
    COUNT(DISTINCT customer_id) AS unique_buyers -- 每日不重複客數
INTO [dbo].[agg_sales_trend]
FROM [dbo].[clean_transactions]
GROUP BY t_dat;