-- 檢查 FN 與 Active 是否為異常值 (非 0 或 1) (無異常值，不更改)
SELECT
    COUNT(*) AS total_rows,
    SUM(CASE WHEN FN IS NULL THEN 1 ELSE 0 END) AS fn_nulls,
    SUM(CASE WHEN TRY_CAST(FN AS FLOAT) IS NULL AND FN IS NOT NULL THEN 1 ELSE 0 END) AS fn_invalid,
    SUM(CASE WHEN Active IS NULL THEN 1 ELSE 0 END) AS active_nulls,
    SUM(CASE WHEN TRY_CAST(Active AS FLOAT) IS NULL AND Active IS NOT NULL THEN 1 ELSE 0 END) AS active_invalid
FROM temp_customers;

